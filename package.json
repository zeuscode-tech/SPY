{
  "name": "spy-ultimate",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "build:cap": "set CAPACITOR_BUILD=true&& next build",
    "cap:sync": "npm run build:cap && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:apk": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:aab": "npm run cap:sync && cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "framer-motion": "^11.0.0",
    "next": "^15.5.15",
    "next-pwa": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
